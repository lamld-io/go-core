# =============================================================================
# Agent & AI Tools
# =============================================================================

# Everything Claude Code agent data (không commit tool nội bộ)
# .agent/ được commit vì chứa skills, workflows dùng chung
# Nhưng ignore các file tạm của agent:
.agent/tmp/
.agent/cache/
.agent/.session/

# Local clone / detached gitlink không còn quản lý trong repo chính
everything-claude-code/

# Claude local settings (có thể chứa API keys/auth tokens)
.claude/settings.local.json

