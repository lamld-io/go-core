# ========================================
# Gateway Service — Environment Variables
# ========================================

# App
APP_ENV=development

# Server
SERVER_PORT=8080
SERVER_READ_TIMEOUT=15s
SERVER_WRITE_TIMEOUT=30s

# JWT (chỉ cần public key để verify — không cần private key)
JWT_PUBLIC_KEY_PATH=configs/keys/public.pem
JWT_ISSUER=auth-service

# Routes configuration file
ROUTES_CONFIG_PATH=configs/routes.yaml

# Rate Limiting (in-memory, per-IP)
RATE_LIMIT_ENABLED=true
RATE_LIMIT_RPS=100
RATE_LIMIT_BURST=200

# Proxy settings
PROXY_TIMEOUT=30s
PROXY_MAX_IDLE_CONNS=100
PROXY_IDLE_CONN_TIMEOUT=90s
