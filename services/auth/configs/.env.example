# ========================================
# Auth Service — Environment Variables
# ========================================

# App
APP_ENV=development

# Server
SERVER_PORT=8081
SERVER_READ_TIMEOUT=15s
SERVER_WRITE_TIMEOUT=15s

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=auth_db
DB_SSLMODE=disable

# JWT (RSA keys)
JWT_PRIVATE_KEY_PATH=configs/keys/private.pem
JWT_PUBLIC_KEY_PATH=configs/keys/public.pem
JWT_ACCESS_TOKEN_TTL=15m
JWT_REFRESH_TOKEN_TTL=168h
JWT_ISSUER=auth-service

# Redis (token blacklist, rate limiting — tuỳ chọn, có fallback in-memory)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Rate Limiting (per-IP, dùng Redis hoặc in-memory fallback)
RATE_LIMIT_LOGIN=5
RATE_LIMIT_GENERAL=100

# Password Policy (tất cả đều configurable)
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=false
PASSWORD_REQUIRE_LOWERCASE=false
PASSWORD_REQUIRE_DIGIT=false
PASSWORD_REQUIRE_SPECIAL=false

# Security Flows
EMAIL_VERIFICATION_TOKEN_TTL=24h
PASSWORD_RESET_TOKEN_TTL=30m
LOGIN_LOCKOUT_MAX_FAILED_ATTEMPTS=5
LOGIN_LOCKOUT_DURATION=15m

# SMTP (leave empty to fallback to log-only sender in local dev)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=no-reply@example.com
SMTP_FROM_NAME=Base Auth
